<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SteelStringTheory.UI.ViewModels"
             x:Class="SteelStringTheory.UI.MainPage"
             x:DataType="vm:FretboardViewModel"
             Title="Fretboard">

    <Grid RowDefinitions="Auto,*" Background="#FAFAFA">

        <!-- Controls bar -->
        <Border Grid.Row="0" Padding="12,8" Background="#EEEEEE"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                <Label Text="Key:"
                       VerticalOptions="Center"
                       Grid.Column="0" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding KeyOptions}"
                        SelectedIndex="{Binding SelectedKeyIndex}"
                        WidthRequest="80" />
                <Picker Grid.Column="2"
                        ItemsSource="{Binding AccidentalOptions}"
                        SelectedIndex="{Binding SelectedAccidentalIndex}"
                        WidthRequest="100" />
                <Label Text="Scale:"
                       VerticalOptions="Center"
                       Grid.Column="3" />
                <Picker Grid.Column="4"
                        ItemsSource="{Binding ModeOptions}"
                        SelectedIndex="{Binding SelectedModeIndex}"
                        WidthRequest="140" />
                <Label Grid.Column="5"
                       Text="{Binding ScaleLabel}"
                       FontAttributes="Bold"
                       FontSize="18"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Padding="10,0" />
            </Grid>
        </Border>

        <!-- Fretboard canvas -->
        <GraphicsView Grid.Row="1"
                      x:Name="FretboardView"
                      Margin="8" />

    </Grid>

</ContentPage>
